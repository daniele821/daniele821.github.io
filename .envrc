#!/bin/bash

SCRIPT_PWD="$(realpath "${BASH_SOURCE[0]}")"
SCRIPT_DIR=$(dirname "${SCRIPT_PWD}")

HOOK="$SCRIPT_DIR/.git/hooks/pre-commit"

echo $HOOK

if ! [[ -f $HOOK ]]; then
    echo '
#!/bin/bash

SCRIPT_PWD="$(realpath "${BASH_SOURCE[0]}")"
SCRIPT_DIR=$(dirname "${SCRIPT_PWD}")

"$SCRIPT_DIR/update.sh"

' >"$HOOK"
fi
